---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="GOSQO | Shopify SaaS & Web Apps"
  description="GOSQO builds Shopify-focused SaaS and web applications."
  canonical="/"
>
  <h1>GOSQO</h1>
  <p>
    We build Shopify-focused SaaS products and web applications. Our work includes customer support tools,
    storefront experiences, and AI-assisted workflows.
  </p>

  <div class="card">
    <h2>What we build</h2>
    <ul>
      <li>Shopify apps (embedded admin + theme app extensions)</li>
      <li>Web applications for merchants and support teams</li>
      <li>AI-assisted workflows for content and operations</li>
    </ul>
    <p class="meta">Contact: <a href="mailto:support@gosqo.com">support@gosqo.com</a></p>
  </div>

  <div class="card">
    <h2>Products</h2>
    <p><strong>GOSQO AI Store Manager</strong> — AI live chat, unified inbox, and product content tools for Shopify.</p>
    <p><strong>VIKNO.APP</strong> — CRM for client records, services, and bookkeeping.</p>
    <p class="meta"><a class="btn" href="/apps">View apps</a></p>
  </div>
</BaseLayout>