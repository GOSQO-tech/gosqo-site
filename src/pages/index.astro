    <ul>
      <li>AI live chat and chatbot-style responses</li>
      <li>AI-assisted unified inbox for support</li>
      <li>Product content optimization and SEO audits</li>
      <li>Workflow automation for common support tasks</li>
    </ul>
    <p class="meta">Support: support@gosqo.com</p>
  </div>
</BaseLayout>