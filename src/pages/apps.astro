  description="Shopify-focused SaaS applications and web apps built by GOSQO."
>
  <h1>Apps</h1>
  <p class="meta">Shopify-focused SaaS applications and web apps.</p>

  <div class="card">
    <h2>GOSQO AI Chat & Store Assistant</h2>
    <p>AI live chat, unified inbox workflows, and product content optimization for Shopify merchants.</p>
    <p class="meta">
      <a class="btn" href="/">Overview</a>
      <a class="btn btn-ghost" href="/help">Help</a>
      <a class="btn btn-ghost" href="/privacy">Privacy</a>
    </p>
  </div>

  <div class="card">
    <h2>More apps</h2>
    <p>Additional products may be listed here as they become available.</p>
  </div>
</BaseLayout>