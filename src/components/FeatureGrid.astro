---
interface Props {
  title?: string;
  items: string[];
}

const { title = "Key capabilities", items } = Astro.props;
---

<section class="feature-grid">
  {title && <h2 class="feature-grid-title">{title}</h2>}
  <ul class="feature-grid-list">
    {items.map((item) => (
      <li class="feature-grid-item">{item}</li>
    ))}
  </ul>
</section>

<style>
  .feature-grid {
    margin: 1.5rem 0;
  }
  .feature-grid-title {
    margin: 0 0 12px;
    font-size: 18px;
  }
  .feature-grid-list {
    display: grid;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .feature-grid-item {
    padding: 12px 14px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 14px;
    color: var(--muted);
  }
</style>
